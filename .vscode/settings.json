{
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.cache/**": true,
    "**/.tox/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/docs/images/videos/**": true
  },
  "search.exclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.cache/**": true,
    "**/.tox/**": true,
    "**/build/**": true,
    "**/dist/**": true
  },
  "python.analysis.exclude": [
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/.cache/**",
    "**/.tox/**",
    "**/build/**",
    "**/dist/**"
  ],
  "python.analysis.indexing": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": false
}
